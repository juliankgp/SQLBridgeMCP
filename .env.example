# SQLBridgeMCP Environment Configuration Template
# Copy this file to .env and fill with your actual database credentials
# NEVER commit the real .env file to version control

# Database Configuration - Choose ONE method:

# === OPTION 1: CONNECTION_STRING (Recommended - Simpler setup) ===
# Provide a complete connection string for your database
# CONNECTION_STRING=Server=localhost;Database=your_database;User Id=your_username;Password=your_password;TrustServerCertificate=true
DB_TYPE=sqlserver          # Still required to specify database type

# === OPTION 2: Individual Variables (Fallback method) ===
# If CONNECTION_STRING is not provided, these individual variables will be used
DB_HOST=localhost          # Your database server hostname
DB_PORT=1433              # Your database port (5432 for PostgreSQL, 3306 for MySQL, 1433 for SQL Server)
DB_NAME=your_database     # Your database name
DB_USER=your_username     # Your database username
DB_PASSWORD=your_password # Your database password

# === Examples for different database types ===
# PostgreSQL with CONNECTION_STRING:
# DB_TYPE=postgresql
# CONNECTION_STRING=postgresql+psycopg://user:password@localhost:5432/dbname

# MySQL with CONNECTION_STRING:  
# DB_TYPE=mysql
# CONNECTION_STRING=mysql+aiomysql://user:password@localhost:3306/dbname

# SQLite (always uses individual variables):
# DB_TYPE=sqlite
# DB_NAME=/path/to/your/database.db

# SQL Server with CONNECTION_STRING (most common):
# DB_TYPE=sqlserver
# CONNECTION_STRING=Server=localhost;Database=mydb;User Id=user;Password=pass;TrustServerCertificate=true

# MCP Server Configuration
MCP_SERVER_NAME=SQLBridgeMCP
MCP_SERVER_VERSION=1.0.0

# Security Configuration
MAX_QUERY_LENGTH=10000    # Maximum allowed SQL query length
QUERY_TIMEOUT=30         # Query timeout in seconds
MAX_ROWS_RETURNED=1000   # Maximum rows returned per query

# Logging Configuration
LOG_LEVEL=INFO           # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/sqlbridge.log